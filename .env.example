APP_NAME="Agenda Médica"
ENV=development
APP_TIMEZONE="America/Sao_Paulo"
APP_PUBLIC_URL="https://agenda-medica-2c9b.onrender.com"

# URL de conexão com o PostgreSQL
# Render: copie de Dashboard → seu banco → Info → Internal Database URL
# Local:  postgresql://postgres:senha@localhost:5432/agenda_medica
DATABASE_URL="postgresql://postgres:password@localhost:5432/agenda_medica"

# Gere uma chave forte (32+ chars) e mantenha em segredo
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY="troque-esta-chave"

# Em produção (Render, Railway, etc.) use true
AUTH_COOKIE_SECURE=false

# Se precisar acessar frontend em outro domínio durante dev:
# CORS_ORIGINS=["http://localhost:5173","http://localhost:8000"]

# ─── E-mail / SMTP ────────────────────────────────────────────────────────────
# Gmail: use uma "Senha de app" (não a senha normal).
#   Ative em: Conta Google → Segurança → Verificação em 2 etapas → Senhas de app
# Outros provedores: ajuste SMTP_HOST e SMTP_PORT conforme necessário.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER="seu@gmail.com"
SMTP_PASSWORD="sua-senha-de-app"
SMTP_FROM_EMAIL="seu@gmail.com"
SMTP_FROM_NAME="Agenda Médica"

# ─── Resend API (alternativa ao SMTP — recomendado em produção cloud) ─────────
# RESEND_API_KEY="re_xxxxxxxxxxxx"

# Mercado Pago / Checkout Pro
MERCADOPAGO_ACCESS_TOKEN="APP_USR-xxxxxxxxxxxxxxxx"

# ─── Web Push / VAPID (notificações push) ─────────────────────────────────────
# Gere as chaves com: python -m backend.scripts.gen_vapid
# VAPID_PUBLIC_KEY=""
# VAPID_PRIVATE_KEY=""
# VAPID_MAILTO="mailto:seu@email.com"

# ─── WhatsApp Cloud API ───────────────────────────────────────────────────────
# Token e Phone Number ID vêm do app no Meta for Developers / WhatsApp Manager.
# Não coloque o token direto no código nem versionado no Git.
# WHATSAPP_ACCESS_TOKEN=""
# WHATSAPP_PHONE_NUMBER_ID=""
# WHATSAPP_BUSINESS_ACCOUNT_ID=""
# WHATSAPP_API_VERSION="v20.0"
# WHATSAPP_DEFAULT_COUNTRY_CODE="55"
# WHATSAPP_TEMPLATE_LANGUAGE="pt_BR"
# WHATSAPP_PATIENT_TEMPLATE_PARAMETER_MODE="standard"
# WHATSAPP_VERIFY_TOKEN=""
# WHATSAPP_APP_SECRET=""
#
# Recomendado em produção: crie templates aprovados no WhatsApp Manager.
# Ordem esperada dos parâmetros do template de paciente:
#   {{1}} primeiro_nome, {{2}} data, {{3}} hora, {{4}} clinica, {{5}} medico
# WHATSAPP_PATIENT_TEMPLATE_NAME=""
#
# Ordem esperada dos parâmetros do template do médico:
#   {{1}} medico, {{2}} data, {{3}} total_dia, {{4}} consultas, {{5}} clinica
# WHATSAPP_DOCTOR_TEMPLATE_NAME=""
