APP_NAME="Agenda Médica"
ENV=development
APP_TIMEZONE="America/Sao_Paulo"

# URL de conexão com o PostgreSQL
# Render: copie de Dashboard → seu banco → Info → Internal Database URL
# Local:  postgresql://postgres:senha@localhost:5432/agenda_medica
DATABASE_URL="postgresql://postgres:password@localhost:5432/agenda_medica"

# Gere uma chave forte (32+ chars) e mantenha em segredo
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY="troque-esta-chave"

# Em produção (Render, Railway, etc.) use true
AUTH_COOKIE_SECURE=false

# Se precisar acessar frontend em outro domínio durante dev:
# CORS_ORIGINS=["http://localhost:5173","http://localhost:8000"]

# ─── E-mail / SMTP ────────────────────────────────────────────────────────────
# Gmail: use uma "Senha de app" (não a senha normal).
#   Ative em: Conta Google → Segurança → Verificação em 2 etapas → Senhas de app
# Outros provedores: ajuste SMTP_HOST e SMTP_PORT conforme necessário.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER="seu@gmail.com"
SMTP_PASSWORD="sua-senha-de-app"
SMTP_FROM_EMAIL="seu@gmail.com"
SMTP_FROM_NAME="Agenda Médica"

# ─── Resend API (alternativa ao SMTP — recomendado em produção cloud) ─────────
# RESEND_API_KEY="re_xxxxxxxxxxxx"

# ─── Web Push / VAPID (notificações push) ─────────────────────────────────────
# Gere as chaves com: python -m backend.scripts.gen_vapid
# VAPID_PUBLIC_KEY=""
# VAPID_PRIVATE_KEY=""
# VAPID_MAILTO="mailto:seu@email.com"
